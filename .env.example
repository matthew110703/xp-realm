# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=XPRealm

# Auth (NextAuth v5)
AUTH_SECRET=                          # generate with: openssl rand -base64 32

# Reddit OAuth (user-facing: for OAuth login + comment posting)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Reddit App-level credentials (for cron fetching, not user auth)
REDDIT_APP_CLIENT_ID=
REDDIT_APP_CLIENT_SECRET=

# Database (Neon PostgreSQL)
DATABASE_URL=                         # postgresql://user:pass@host/db?sslmode=require

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=                        # https://pub-xxx.r2.dev

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Adzuna Jobs API
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Web Push (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# Cron Security (secret header for Vercel Cron endpoint)
CRON_SECRET=                          # any strong random string

# Scraping config
SCRAPE_TIMEOUT_MS=15000
SCRAPE_MAX_CONCURRENT=3

# Telegram Bot
TELEGRAM_BOT_TOKEN=                   # from @BotFather
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=    # e.g. XPRealmBot

# Encryption (for HN session cookies)
# Generate: openssl rand -hex 32  (must be exactly 64 hex chars)
ENCRYPTION_KEY=7cc65fa20f53b298b8f69b5881f1315676d8d177249519ac6b106dc65a97a6b3
