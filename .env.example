# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=XPRealm

# Auth (NextAuth v5)
AUTH_SECRET=                          # generate with: openssl rand -base64 32

# Reddit OAuth (user-facing: for OAuth login + comment posting)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Reddit App-level credentials (for cron fetching, not user auth)
REDDIT_APP_CLIENT_ID=
REDDIT_APP_CLIENT_SECRET=

# Database (Neon PostgreSQL)
DATABASE_URL=                         # postgresql://user:pass@host/db?sslmode=require

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=                        # https://pub-xxx.r2.dev

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Adzuna Jobs API
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Numbeo API (cost of living data)
NUMBEO_API_KEY=

# Web Push (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# Cron Security (secret header for Vercel Cron endpoint)
CRON_SECRET=                          # any strong random string
